<?xml version="1.0" encoding="UTF-8" ?>
<ldlib2-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/Low-Drag-MC/LDLib2/refs/heads/1.21/ldlib2-ui.xsd">
    <stylesheet location="ldlib2:lss/mc.lss"/>
    <style>
        #item-selection-root {
        width: 100%;
        height: 100%;
        overflow: hidden;
        }

        #item-selection-panel {
        position: absolute;
        width: 176;
        height: 174;
        overflow: hidden;
        }

        #dim-overlay {
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        }

        #title-label {
        position: absolute;
        left: 8;
        top: 5;
        width: 72;
        height: 10;
        text-wrap: HIDE;
        vertical-align: CENTER;
        text-shadow: false;
        }

        #action-row {
        position: absolute;
        left: 8;
        top: 16;
        width: 160;
        height: 20;
        flex-direction: row;
        gap-all: 2;
        }

        #mode-label {
        width: 58;
        height: 20;
        flex-shrink: 1;
        text-wrap: HIDE;
        vertical-align: CENTER;
        text-shadow: false;
        }

        .action-button {
        width: 54;
        height: 20;
        flex-shrink: 0;
        }

        #back-button {
        width: 48;
        height: 20;
        flex-shrink: 0;
        }

        #selection-slot-label {
        position: absolute;
        left: 8;
        top: 40;
        width: 78;
        height: 10;
        text-wrap: HIDE;
        vertical-align: CENTER;
        text-shadow: false;
        }

        #restriction-label {
        position: absolute;
        left: 8;
        top: 52;
        width: 160;
        height: 10;
        text-wrap: HIDE;
        vertical-align: CENTER;
        text-shadow: false;
        }

        #selected-item-label {
        position: absolute;
        left: 8;
        top: 64;
        width: 160;
        height: 12;
        text-wrap: HIDE;
        vertical-align: CENTER;
        text-shadow: false;
        }

        #inventory-label {
        position: absolute;
        left: 8;
        top: 73;
        width: 80;
        height: 10;
        text-wrap: HIDE;
        vertical-align: CENTER;
        text-shadow: false;
        }

        #slot-background-layer {
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        }
    </style>
    <root id="item-selection-root">
        <element id="dim-overlay"/>
        <element id="item-selection-panel">
            <element id="slot-background-layer"/>
            <label id="title-label"/>
            <element id="action-row">
                <label id="mode-label"/>
                <button id="confirm-button" class="action-button" text="gui.wheatmarket.item_selection.confirm"/>
                <button id="back-button" class="action-button" text="gui.wheatmarket.item_selection.back"/>
            </element>
            <label id="selection-slot-label"/>
            <label id="restriction-label"/>
            <label id="selected-item-label"/>
            <label id="inventory-label"/>
        </element>
    </root>
</ldlib2-ui>
