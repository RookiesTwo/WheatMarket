<?xml version="1.0" encoding="UTF-8" ?>
<ldlib2-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/Low-Drag-MC/LDLib2/refs/heads/1.21/ldlib2-ui.xsd">
    <stylesheet location="ldlib2:lss/mc.lss"/>
    <style>
        #market-root {
        width: 100%;
        height: 100%;
        flex-direction: column;
        padding-all: 8;
        gap-all: 6;
        overflow: hidden;
        }

        .row-bar {
        width: 100%;
        flex-direction: row;
        gap-all: 6;
        align-items: center;
        }

        #top-bar {
        height: 34;
        gap-all: 6;
        padding-left: 8;
        padding-right: 8;
        overflow: hidden;
        flex-wrap: nowrap;
        }

        #title-logo {
        height: 80%;
        aspect-rate: 8;
        min-width: 180;
        max-width: 260;
        min-height: 20;
        align-self: center;
        transform: translateY(2);
        flex-shrink: 1;
        }

        #top-spacer {
        width: 0;
        min-width: 0;
        flex: 1;
        }

        #account-panel {
        width: 18%;
        min-width: 150;
        max-width: 210;
        height: 22;
        flex-direction: row;
        align-items: center;
        gap-all: 4;
        padding-left: 2;
        padding-right: 2;
        flex-shrink: 0;
        overflow: hidden;
        }

        #my-items-button {
        width: 22;
        height: 22;
        flex-shrink: 0;
        }

        #balance-label {
        width: 0;
        flex: 1;
        min-width: 0;
        height: 100%;
        padding-left: 6;
        padding-right: 6;
        overflow: hidden;
        text-wrap: HIDE;
        vertical-align: CENTER;
        text-color: #2B2116;
        text-shadow: false;
        }

        #content-shell {
        width: 100%;
        flex: 1;
        flex-direction: row;
        gap-all: 6;
        overflow: hidden;
        }

        #side-bar {
        width: 76;
        height: 100%;
        flex-direction: column;
        padding-all: 7;
        gap-all: 4;
        flex-shrink: 0;
        overflow: hidden;
        }

        #trade-selector,
        #source-selector {
        width: 100%;
        height: 20;
        text-color: #3F3F3F;
        text-shadow: false;
        flex-shrink: 0;
        }

        #sort-row {
        width: 100%;
        height: 20;
        flex-direction: row;
        gap-all: 4;
        align-items: center;
        flex-shrink: 0;
        }

        #sort-selector {
        width: 0;
        min-width: 0;
        flex: 1;
        height: 20;
        text-color: #3F3F3F;
        text-shadow: false;
        }

        #sort-button {
        width: 20;
        height: 20;
        flex-shrink: 0;
        }

        #listing-button {
        align-self: stretch;
        height: 0;
        flex: 1;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap-all: 4;
        padding-all: 6;
        margin-all: 3;
        min-height: 0;
        flex-shrink: 1;
        }

        #delivery-button {
        width: 100%;
        height: 28;
        min-height: 28;
        flex-shrink: 0;
        margin-left: 3;
        margin-right: 3;
        }

        #listing-button > text:internal {
        width: 100%;
        height: 14;
        margin-all: 0;
        flex-shrink: 0;
        }

        #main-column {
        flex: 1;
        height: 100%;
        flex-direction: column;
        gap-all: 6;
        overflow: hidden;
        }

        #action-bar {
        height: 26;
        padding-left: 6;
        padding-right: 6;
        }

        #search-field {
        flex: 1;
        height: 20;
        padding-left: 8;
        padding-right: 8;
        text-color: #151515;
        cursor-color: #151515;
        error-color: #8C1D18;
        text-shadow: false;
        }

        .action-button {
        width: 54;
        height: 20;
        }

        #market-panel {
        width: 100%;
        flex: 1;
        padding-all: 7;
        gap-all: 6;
        overflow: hidden;
        }

        #product-board {
        width: 100%;
        flex: 1;
        flex-direction: row;
        flex-wrap: wrap;
        gap-all: 10;
        justify-content: flex-start;
        align-content: flex-start;
        align-items: flex-start;
        overflow: hidden;
        }

        #pagination-bar {
        width: 100%;
        height: 24;
        flex-direction: row;
        gap-all: 8;
        align-items: center;
        padding-left: 8;
        padding-right: 8;
        }

        .page-button {
        width: 68;
        height: 20;
        }

        #page-label {
        flex: 1;
        height: 16;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        }
    </style>
    <root id="market-root" class="panel_bg">
        <element id="top-bar" class="row-bar">
            <element id="title-logo"/>
            <element id="top-spacer"/>
            <element id="account-panel">
                <button id="my-items-button" text=""/>
                <label id="balance-label"/>
            </element>
        </element>
        <element id="content-shell">
            <element id="side-bar">
                <selector id="trade-selector"/>
                <selector id="source-selector"/>
                <element id="sort-row">
                    <selector id="sort-selector"/>
                    <button id="sort-button" text=""/>
                </element>
                <button id="listing-button" text="gui.wheatmarket.nav.listing"/>
                <button id="delivery-button" text="gui.wheatmarket.nav.delivery"/>
            </element>
            <element id="main-column">
                <element id="action-bar" class="row-bar">
                    <text-field id="search-field" value=""/>
                    <button id="search-button" class="action-button" text="gui.wheatmarket.action.search"/>
                    <button id="refresh-button" class="action-button" text="gui.wheatmarket.action.refresh"/>
                </element>
                <element id="market-panel">
                    <element id="product-board"/>
                </element>
            </element>
        </element>
        <element id="pagination-bar">
            <button id="previous-button" class="page-button" text="gui.wheatmarket.action.previous"/>
            <label id="page-label"/>
            <button id="next-button" class="page-button" text="gui.wheatmarket.action.next"/>
        </element>
    </root>
</ldlib2-ui>
