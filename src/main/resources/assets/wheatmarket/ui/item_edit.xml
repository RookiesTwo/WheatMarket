<?xml version="1.0" encoding="UTF-8" ?>
<ldlib2-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/Low-Drag-MC/LDLib2/refs/heads/1.21/ldlib2-ui.xsd">
    <stylesheet location="ldlib2:lss/mc.lss"/>
    <style>
        #item-edit-root {
        width: 100%;
        height: 100%;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap-all: 6;
        padding-all: 6;
        overflow: visible;
        }

        #player-column {
        width: 26%;
        min-width: 84;
        max-width: 170;
        height: 100%;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap-all: 10;
        flex-shrink: 0;
        overflow: hidden;
        }

        #player-avatar {
        width: 54;
        height: 54;
        max-width: 100%;
        flex-shrink: 0;
        }

        #player-balance {
        width: 100%;
        height: 22;
        min-height: 18;
        flex-shrink: 0;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        }

        #item-edit-paper {
        width: 0;
        flex: 1;
        min-width: 212;
        max-width: 332;
        height: 100%;
        min-height: 260;
        max-height: 350;
        flex-direction: column;
        align-items: center;
        gap-all: 5;
        padding-left: 12;
        padding-right: 12;
        padding-top: 18;
        padding-bottom: 15;
        overflow: visible;
        }

        #item-edit-title {
        width: 68%;
        min-width: 130;
        max-width: 220;
        height: 24;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 0;
        }

        #item-edit-main {
        width: 100%;
        flex: 1;
        min-height: 0;
        flex-direction: row;
        gap-all: 6;
        overflow: hidden;
        }

        #item-edit-left {
        width: 42%;
        min-width: 76;
        max-width: 138;
        height: 100%;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap-all: 5;
        padding-left: 4;
        padding-right: 2;
        flex-shrink: 1;
        overflow: hidden;
        }

        #owner-label {
        width: 100%;
        height: 22;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 0;
        }

        #item-preview {
        width: 46;
        height: 46;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
        }

        #edit-item-icon {
        width: 34;
        height: 34;
        flex-shrink: 0;
        }

        .summary-label {
        width: 100%;
        height: 21;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 0;
        }

        #item-edit-right {
        width: 0;
        flex: 1;
        min-width: 0;
        height: 100%;
        min-height: 0;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap-all: 3;
        padding-left: 2;
        padding-right: 4;
        flex-shrink: 1;
        overflow: hidden;
        }

        .info-label {
        width: 100%;
        height: 18;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 0;
        }

        .form-row {
        width: 100%;
        max-width: 100%;
        height: 22;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap-all: 4;
        flex-shrink: 0;
        overflow: hidden;
        }

        .form-caption {
        width: 38%;
        min-width: 40;
        max-width: 56;
        height: 22;
        horizontal-align: RIGHT;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 0;
        }

        .input-field {
        width: 0;
        flex: 1;
        min-width: 48;
        max-width: 86;
        height: 22;
        padding-left: 6;
        padding-right: 6;
        text-color: #19140D;
        cursor-color: #19140D;
        error-color: #A33629;
        text-shadow: false;
        flex-shrink: 1;
        }

        #current-stock-label {
        width: 0;
        flex: 1;
        min-width: 48;
        max-width: 86;
        height: 22;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 1;
        }

        .small-button {
        width: 86;
        min-width: 64;
        max-width: 98;
        height: 22;
        flex-shrink: 0;
        }

        #stock-buttons-row {
        width: 100%;
        height: 22;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap-all: 4;
        flex-shrink: 0;
        overflow: hidden;
        }

        #stock-edit-button {
        width: 70%;
        min-width: 74;
        max-width: 120;
        height: 22;
        flex-shrink: 0;
        }

        #op-panel {
        width: 100%;
        height: 96;
        flex-direction: column;
        align-items: center;
        gap-all: 3;
        flex-shrink: 0;
        overflow: hidden;
        }

        #op-title {
        width: 100%;
        height: 16;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 0;
        }

        #op-toggle-row {
        width: 100%;
        height: 22;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap-all: 4;
        flex-shrink: 0;
        overflow: hidden;
        }

        #toggle-admin-button, #toggle-infinite-button {
        width: 0;
        flex: 1;
        min-width: 56;
        max-width: 94;
        height: 22;
        flex-shrink: 1;
        }

        #cooldown-apply-button {
        width: 70%;
        min-width: 74;
        max-width: 120;
        height: 22;
        flex-shrink: 0;
        }

        #feedback-label {
        width: 100%;
        height: 18;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 0;
        }

        #action-column {
        width: 26%;
        min-width: 84;
        max-width: 170;
        height: 100%;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap-all: 8;
        flex-shrink: 1;
        overflow: hidden;
        }

        #delist-button {
        width: 96;
        min-width: 64;
        max-width: 96;
        height: 36;
        flex-shrink: 0;
        }

        #cancel-button {
        width: 96;
        min-width: 64;
        max-width: 96;
        height: 52;
        flex-shrink: 0;
        }
    </style>
    <root id="item-edit-root">
        <element id="player-column">
            <element id="player-avatar"/>
            <label id="player-balance"/>
        </element>
        <element id="item-edit-paper">
            <label id="item-edit-title"/>
            <element id="item-edit-main">
                <element id="item-edit-left">
                    <label id="owner-label"/>
                    <element id="item-preview">
                        <element id="edit-item-icon"/>
                    </element>
                    <label id="item-name-label" class="summary-label"/>
                    <label id="type-label" class="summary-label"/>
                    <label id="stock-label" class="summary-label"/>
                </element>
                <element id="item-edit-right">
                    <label id="listing-time-label" class="info-label"/>
                    <label id="last-trade-label" class="info-label"/>
                    <element id="price-row" class="form-row">
                        <label id="price-caption" class="form-caption"/>
                        <text-field id="price-field" class="input-field" value="1.00"/>
                    </element>
                    <button id="price-apply-button" class="small-button" text="gui.wheatmarket.edit.apply_price"/>
                    <element id="stock-row" class="form-row">
                        <label id="stock-caption" class="form-caption"/>
                        <label id="current-stock-label"/>
                    </element>
                    <element id="stock-buttons-row">
                        <button id="stock-edit-button" text="gui.wheatmarket.edit.edit_stock"/>
                    </element>
                    <element id="op-panel">
                        <label id="op-title"/>
                        <element id="op-toggle-row">
                            <button id="toggle-admin-button" text="gui.wheatmarket.edit.toggle_admin"/>
                            <button id="toggle-infinite-button" text="gui.wheatmarket.edit.toggle_infinite"/>
                        </element>
                        <element id="cooldown-amount-row" class="form-row">
                            <label id="cooldown-amount-caption" class="form-caption"/>
                            <text-field id="cooldown-amount-field" class="input-field" value="0"/>
                        </element>
                        <element id="cooldown-time-row" class="form-row">
                            <label id="cooldown-time-caption" class="form-caption"/>
                            <text-field id="cooldown-time-field" class="input-field" value="0"/>
                        </element>
                        <button id="cooldown-apply-button" text="gui.wheatmarket.edit.apply_cooldown"/>
                    </element>
                </element>
            </element>
            <label id="feedback-label"/>
        </element>
        <element id="action-column">
            <button id="delist-button" text="gui.wheatmarket.edit.delist"/>
            <button id="cancel-button" text="gui.wheatmarket.edit.back"/>
        </element>
    </root>
</ldlib2-ui>
