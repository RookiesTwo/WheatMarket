<?xml version="1.0" encoding="UTF-8" ?>
<ldlib2-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/Low-Drag-MC/LDLib2/refs/heads/1.21/ldlib2-ui.xsd">
    <stylesheet location="ldlib2:lss/mc.lss"/>
    <style>
        #order-root {
        width: 100%;
        height: 100%;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap-all: 6;
        padding-all: 6;
        overflow: visible;
        }

        #player-column {
        width: 26%;
        min-width: 84;
        max-width: 170;
        height: 100%;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap-all: 10;
        flex-shrink: 0;
        overflow: hidden;
        }

        #player-avatar {
        width: 54;
        height: 54;
        max-width: 100%;
        flex-shrink: 0;
        }

        #player-balance {
        width: 100%;
        height: 22;
        min-height: 18;
        flex-shrink: 0;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        }

        #order-paper {
        width: 0;
        flex: 1;
        min-width: 190;
        max-width: 280;
        height: 100%;
        min-height: 242;
        max-height: 330;
        flex-direction: column;
        align-items: center;
        gap-all: 5;
        padding-left: 12;
        padding-right: 12;
        padding-top: 22;
        padding-bottom: 24;
        overflow: visible;
        }

        #order-title {
        width: 62%;
        min-width: 120;
        max-width: 190;
        height: 24;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 0;
        }

        #order-main {
        width: 100%;
        flex: 1;
        min-height: 0;
        flex-direction: row;
        gap-all: 8;
        overflow: visible;
        }

        #order-left {
        width: 36%;
        min-width: 74;
        max-width: 110;
        height: 100%;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap-all: 4;
        padding-left: 12;
        flex-shrink: 0;
        overflow: visible;
        }

        #owner-label {
        width: 100%;
        height: 26;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 0;
        }

        #item-preview {
        width: 46;
        height: 46;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
        }

        #order-item-icon {
        width: 34;
        height: 34;
        flex-shrink: 0;
        }

        #unit-price-label {
        width: 82%;
        height: 20;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 0;
        }

        #order-right {
        width: 0;
        flex: 1;
        height: 100%;
        min-height: 0;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap-all: 4;
        overflow: hidden;
        }

        .info-label {
        width: 100%;
        height: 22;
        min-height: 14;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 1;
        }

        #listing-time-label {
        width: 100%;
        max-width: 100%;
        height: 22;
        min-height: 18;
        flex-shrink: 0;
        }

        #restriction-panel {
        width: 100%;
        height: 34;
        min-height: 27;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap-all: 1;
        flex-shrink: 1;
        overflow: hidden;
        }

        .restriction-label {
        width: 100%;
        height: 13;
        min-height: 12;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 1;
        }

        #quantity-row {
        width: 62%;
        min-width: 130;
        max-width: 240;
        height: 24;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap-all: 7;
        flex-shrink: 0;
        }

        #quantity-caption {
        width: 64;
        min-width: 64;
        height: 22;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        flex-shrink: 0;
        }

        #quantity-controls {
        height: 24;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap-all: 7;
        flex-shrink: 0;
        }

        .quantity-button {
        width: 24;
        height: 24;
        flex-shrink: 0;
        }

        #quantity-field {
        width: 24;
        min-width: 20;
        max-width: 64;
        height: 22;
        padding-left: 8;
        padding-right: 8;
        text-color: #19140D;
        cursor-color: #19140D;
        error-color: #A33629;
        text-shadow: false;
        flex-shrink: 0;
        }

        #confirm-area {
        width: 62%;
        min-width: 140;
        max-width: 230;
        height: 42;
        flex-direction: column;
        gap-all: 2;
        padding-bottom: 2;
        flex-shrink: 0;
        }

        #confirm-state-slot {
        width: 100%;
        height: 34;
        flex-shrink: 0;
        }

        .confirm-state-element {
        width: 100%;
        height: 100%;
        flex-shrink: 0;
        }

        #error-progress-track {
        width: 100%;
        height: 4;
        flex-direction: row;
        flex-shrink: 0;
        overflow: hidden;
        }

        #error-progress-fill {
        width: 0;
        height: 100%;
        flex-shrink: 0;
        }

        #feedback-label {
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        }

        #signature-label {
        position-type: absolute;
        width: 1;
        height: 1;
        horizontal-align: CENTER;
        vertical-align: CENTER;
        text-wrap: HIDE;
        text-shadow: false;
        }

        #stamp-overlay {
        position-type: absolute;
        width: 1;
        height: 1;
        }

        #action-column {
        width: 26%;
        min-width: 84;
        max-width: 170;
        height: 100%;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap-all: 8;
        flex-shrink: 1;
        overflow: hidden;
        }

        #manage-button {
        width: 76;
        min-width: 64;
        max-width: 88;
        height: 24;
        flex-shrink: 0;
        }

        #cancel-button {
        width: 96;
        min-width: 64;
        max-width: 96;
        height: 76;
        flex-shrink: 0;
        }
    </style>
    <root id="order-root">
        <element id="player-column">
            <element id="player-avatar"/>
            <label id="player-balance"/>
        </element>
        <element id="order-paper">
            <label id="order-title"/>
            <element id="order-main">
                <element id="order-left">
                    <label id="owner-label"/>
                    <element id="item-preview">
                        <element id="order-item-icon"/>
                    </element>
                    <label id="unit-price-label"/>
                </element>
                <element id="order-right">
                    <label id="item-name-label" class="info-label"/>
                    <label id="stock-label" class="info-label"/>
                    <element id="restriction-panel">
                        <label id="restriction-time-label" class="restriction-label"/>
                        <label id="restriction-amount-label" class="restriction-label"/>
                    </element>
                </element>
            </element>
            <label id="listing-time-label" class="info-label"/>
            <element id="quantity-row">
                <label id="quantity-caption" text="gui.wheatmarket.confirm.quantity_label"/>
                <element id="quantity-controls">
                    <button id="decrease-button" class="quantity-button" text="-"/>
                    <text-field id="quantity-field" value="1"/>
                    <button id="increase-button" class="quantity-button" text="+"/>
                </element>
            </element>
            <element id="confirm-area">
                <element id="confirm-state-slot">
                    <button id="confirm-button" class="confirm-state-element" text=""/>
                    <label id="processing-label" class="confirm-state-element"/>
                    <label id="feedback-label" class="confirm-state-element"/>
                </element>
                <element id="error-progress-track">
                    <element id="error-progress-fill"/>
                </element>
            </element>
        </element>
        <label id="signature-label"/>
        <element id="stamp-overlay"/>
        <element id="action-column">
            <button id="manage-button" text="gui.wheatmarket.confirm.manage"/>
            <button id="cancel-button" text="gui.wheatmarket.confirm.cancel"/>
        </element>
    </root>
</ldlib2-ui>
